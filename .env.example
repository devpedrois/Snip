# App
APP_PORT=8080
APP_ENV=development
BASE_URL=http://localhost:8080

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=shortener
MYSQL_PASSWORD=shortener_pass
MYSQL_DATABASE=snip
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DAYS=30

# Analytics
ANALYTICS_WORKERS=4
ANALYTICS_BUFFER=1000

# URL
URL_EXPIRATION_DAYS=30

# VirusTotal
VIRUSTOTAL_API_KEY=
VT_ENABLED=true
VT_TIMEOUT_SECONDS=10
VT_MIN_POSITIVES=2
VT_CACHE_TTL_HOURS=24
VT_RESCAN_INTERVAL_HOURS=6
